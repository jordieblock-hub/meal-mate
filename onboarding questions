<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Meal Mate — Get Started</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green: #3a7d44;
      --green-light: #e8f5ea;
      --green-mid: #c5e3c8;
      --cream: #faf8f3;
      --text: #1c2b1e;
      --muted: #6b7f6d;
      --border: #d4e0d5;
      --chip-bg: #fff;
      --chip-sel: #3a7d44;
      --chip-sel-text: #fff;
      --card-bg: #ffffff;
      --radius: 14px;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 2rem 1rem 4rem;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 2rem;
    }
    .brand-icon {
      width: 38px; height: 38px;
      background: var(--green);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .brand-name {
      font-family: 'DM Serif Display', serif;
      font-size: 22px;
      color: var(--green);
      letter-spacing: -0.3px;
    }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem 2rem 1.5rem;
      width: 100%;
      max-width: 520px;
      box-shadow: 0 2px 20px rgba(58,125,68,0.06);
    }

    .progress-wrap {
      margin-bottom: 1.75rem;
    }
    .progress-meta {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .progress-track {
      height: 5px;
      background: var(--green-mid);
      border-radius: 99px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: var(--green);
      border-radius: 99px;
      transition: width 0.4s ease;
    }

    .step { display: none; }
    .step.active { display: block; }

    .step-tag {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--green);
      background: var(--green-light);
      padding: 3px 10px;
      border-radius: 99px;
      display: inline-block;
      margin-bottom: 0.75rem;
    }

    .step-title {
      font-family: 'DM Serif Display', serif;
      font-size: 22px;
      line-height: 1.3;
      color: var(--text);
      margin-bottom: 1.25rem;
    }

    .chip-group {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 0.5rem;
    }

    .chip {
      padding: 7px 16px;
      border-radius: 99px;
      border: 1.5px solid var(--border);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      cursor: pointer;
      background: var(--chip-bg);
      color: var(--text);
      transition: all 0.15s ease;
      user-select: none;
    }
    .chip:hover { border-color: var(--green); }
    .chip.selected {
      background: var(--chip-sel);
      color: var(--chip-sel-text);
      border-color: var(--chip-sel);
    }

    .budget-num {
      font-family: 'DM Serif Display', serif;
      font-size: 38px;
      color: var(--green);
      margin-bottom: 0.5rem;
    }
    input[type=range] {
      width: 100%;
      accent-color: var(--green);
      margin-bottom: 4px;
    }
    .range-row {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 1rem;
    }

    .sub-label {
      font-size: 13px;
      color: var(--muted);
      margin: 1rem 0 0.5rem;
    }

    .nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 2rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--border);
    }
    .btn {
      padding: 10px 22px;
      border-radius: 99px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      border: 1.5px solid var(--border);
      background: transparent;
      color: var(--muted);
      transition: all 0.15s;
    }
    .btn:hover { border-color: var(--green); color: var(--green); }
    .btn.primary {
      background: var(--green);
      color: #fff;
      border-color: var(--green);
    }
    .btn.primary:hover { background: #2e6636; }

    .finish-screen {
      display: none;
      text-align: center;
      padding: 1rem 0;
    }
    .finish-icon {
      font-size: 48px;
      margin-bottom: 1rem;
    }
    .finish-title {
      font-family: 'DM Serif Display', serif;
      font-size: 26px;
      color: var(--green);
      margin-bottom: 0.5rem;
    }
    .finish-sub {
      font-size: 15px;
      color: var(--muted);
      line-height: 1.6;
    }
    .finish-btn {
      display: inline-block;
      margin-top: 1.5rem;
      padding: 12px 32px;
      background: var(--green);
      color: #fff;
      border-radius: 99px;
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      font-family: 'DM Sans', sans-serif;
    }
  </style>
</head>
<body>

  <div class="brand">
    <div class="brand-icon">🥗</div>
    <span class="brand-name">meal-mate</span>
  </div>

  <div class="card">

    <!-- Progress -->
    <div class="progress-wrap">
      <div class="progress-meta">
        <span id="prog-label">Step 1 of 7</span>
        <span id="prog-pct">14%</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" id="progress-fill" style="width: 14%;"></div>
      </div>
    </div>

    <!-- Step 1: Budget -->
    <div class="step active" id="step-1">
      <span class="step-tag">💰 Finances</span>
      <h2 class="step-title">What's your weekly grocery budget?</h2>
      <div class="budget-num" id="budget-display">$50</div>
      <input type="range" min="10" max="200" step="5" value="50" id="budget-range"
        oninput="document.getElementById('budget-display').textContent='$'+this.value" />
      <div class="range-row"><span>$10</span><span>$200+</span></div>
    </div>

    <!-- Step 2: Dietary restrictions -->
    <div class="step" id="step-2">
      <span class="step-tag">🥦 Diet</span>
      <h2 class="step-title">Any dietary restrictions?</h2>
      <p style="font-size:13px; color:var(--muted); margin-bottom:1rem;">Select all that apply.</p>
      <div class="chip-group">
        <span class="chip" onclick="toggle(this)">None</span>
        <span class="chip" onclick="toggle(this)">Vegetarian</span>
        <span class="chip" onclick="toggle(this)">Vegan</span>
        <span class="chip" onclick="toggle(this)">Gluten-free</span>
        <span class="chip" onclick="toggle(this)">Dairy-free</span>
        <span class="chip" onclick="toggle(this)">Halal</span>
        <span class="chip" onclick="toggle(this)">Kosher</span>
        <span class="chip" onclick="toggle(this)">Low-carb / Keto</span>
        <span class="chip" onclick="toggle(this)">Paleo</span>
      </div>
    </div>

    <!-- Step 3: Allergies -->
    <div class="step" id="step-3">
      <span class="step-tag">⚠️ Allergies</span>
      <h2 class="step-title">Any food allergies we should know about?</h2>
      <p style="font-size:13px; color:var(--muted); margin-bottom:1rem;">Select all that apply.</p>
      <div class="chip-group">
        <span class="chip" onclick="toggle(this)">None</span>
        <span class="chip" onclick="toggle(this)">Peanuts</span>
        <span class="chip" onclick="toggle(this)">Tree nuts</span>
        <span class="chip" onclick="toggle(this)">Shellfish</span>
        <span class="chip" onclick="toggle(this)">Fish</span>
        <span class="chip" onclick="toggle(this)">Eggs</span>
        <span class="chip" onclick="toggle(this)">Soy</span>
        <span class="chip" onclick="toggle(this)">Wheat</span>
        <span class="chip" onclick="toggle(this)">Sesame</span>
      </div>
    </div>

    <!-- Step 4: Kitchen tools -->
    <div class="step" id="step-4">
      <span class="step-tag">🍳 Kitchen</span>
      <h2 class="step-title">What cooking equipment do you have?</h2>
      <p style="font-size:13px; color:var(--muted); margin-bottom:1rem;">Select all that apply.</p>
      <div class="chip-group">
        <span class="chip" onclick="toggle(this)">Stovetop</span>
        <span class="chip" onclick="toggle(this)">Oven</span>
        <span class="chip" onclick="toggle(this)">Microwave</span>
        <span class="chip" onclick="toggle(this)">Air fryer</span>
        <span class="chip" onclick="toggle(this)">Instant Pot</span>
        <span class="chip" onclick="toggle(this)">Blender</span>
        <span class="chip" onclick="toggle(this)">Rice cooker</span>
        <span class="chip" onclick="toggle(this)">Toaster oven</span>
        <span class="chip" onclick="toggle(this)">Hot plate only</span>
      </div>
    </div>

    <!-- Step 5: Skill level -->
    <div class="step" id="step-5">
      <span class="step-tag">👨‍🍳 Skill level</span>
      <h2 class="step-title">How comfortable are you in the kitchen?</h2>
      <div class="chip-group" style="flex-direction: column; gap: 10px;">
        <span class="chip" style="border-radius: 10px; padding: 12px 16px;" onclick="solo(this)">
          🙂 <strong>Beginner</strong> — I mostly reheat or make simple meals
        </span>
        <span class="chip" style="border-radius: 10px; padding: 12px 16px;" onclick="solo(this)">
          😊 <strong>Intermediate</strong> — I can follow a recipe
        </span>
        <span class="chip" style="border-radius: 10px; padding: 12px 16px;" onclick="solo(this)">
          😎 <strong>Confident</strong> — I cook regularly without much help
        </span>
      </div>
    </div>

    <!-- Step 6: Habit goals -->
    <div class="step" id="step-6">
      <span class="step-tag">🎯 Goals</span>
      <h2 class="step-title">What healthy habits do you want to build?</h2>
      <p style="font-size:13px; color:var(--muted); margin-bottom:1rem;">Select all that apply.</p>
      <div class="chip-group">
        <span class="chip" onclick="toggle(this)">Meal prep on Sundays</span>
        <span class="chip" onclick="toggle(this)">Eat breakfast daily</span>
        <span class="chip" onclick="toggle(this)">Reduce takeout</span>
        <span class="chip" onclick="toggle(this)">Drink more water</span>
        <span class="chip" onclick="toggle(this)">Reduce food waste</span>
        <span class="chip" onclick="toggle(this)">Track nutrition</span>
        <span class="chip" onclick="toggle(this)">Cook at home 5x/week</span>
        <span class="chip" onclick="toggle(this)">Eat more vegetables</span>
      </div>
    </div>

    <!-- Step 7: Reminders -->
    <div class="step" id="step-7">
      <span class="step-tag">🔔 Reminders</span>
      <h2 class="step-title">When should we send habit reminders?</h2>
      <p style="font-size:13px; color:var(--muted); margin-bottom:1rem;">Select all that apply.</p>
      <div class="chip-group">
        <span class="chip" onclick="toggle(this)">Morning (7–9 AM)</span>
        <span class="chip" onclick="toggle(this)">Midday (12–1 PM)</span>
        <span class="chip" onclick="toggle(this)">Evening (6–8 PM)</span>
        <span class="chip" onclick="toggle(this)">Before grocery day</span>
      </div>

      <p class="sub-label">What's your usual grocery day?</p>
      <div class="chip-group">
        <span class="chip" onclick="solo(this)">Mon</span>
        <span class="chip" onclick="solo(this)">Tue</span>
        <span class="chip" onclick="solo(this)">Wed</span>
        <span class="chip" onclick="solo(this)">Thu</span>
        <span class="chip" onclick="solo(this)">Fri</span>
        <span class="chip" onclick="solo(this)">Sat</span>
        <span class="chip" onclick="solo(this)">Sun</span>
      </div>
    </div>

    <!-- Finish screen -->
    <div class="finish-screen" id="finish-screen">
      <div class="finish-icon">🥗</div>
      <h2 class="finish-title">You're all set!</h2>
      <p class="finish-sub">Meal Mate will use your profile to build your personalized shopping list, recipes, and habit reminders.</p>
      <a href="index.html" class="finish-btn">Go to my dashboard →</a>
    </div>

    <!-- Navigation -->
    <div class="nav" id="nav-bar">
      <button class="btn" id="back-btn" onclick="go(-1)" style="visibility: hidden;">← Back</button>
      <button class="btn primary" id="next-btn" onclick="go(1)">Next →</button>
    </div>

  </div>

  <script>
    let current = 1;
    const total = 7;

    function updateProgress() {
      const pct = Math.round((current / total) * 100);
      document.getElementById('progress-fill').style.width = pct + '%';
      document.getElementById('prog-label').textContent = 'Step ' + current + ' of ' + total;
      document.getElementById('prog-pct').textContent = pct + '%';
      document.getElementById('back-btn').style.visibility = current === 1 ? 'hidden' : 'visible';
      document.getElementById('next-btn').textContent = current === total ? 'Finish ✓' : 'Next →';
    }

    function go(dir) {
      if (dir === 1 && current === total) {
        // Show finish screen
        document.getElementById('step-' + current).classList.remove('active');
        document.getElementById('finish-screen').style.display = 'block';
        document.getElementById('nav-bar').style.display = 'none';
        document.getElementById('progress-fill').style.width = '100%';
        document.getElementById('prog-label').textContent = 'Complete!';
        document.getElementById('prog-pct').textContent = '100%';
        return;
      }
      document.getElementById('step-' + current).classList.remove('active');
      current = Math.max(1, Math.min(total, current + dir));
      document.getElementById('step-' + current).classList.add('active');
      updateProgress();
    }

    function toggle(el) {
      el.classList.toggle('selected');
    }

    function solo(el) {
      el.closest('.chip-group').querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
      el.classList.add('selected');
    }

    updateProgress();
  </script>
</body>
</html>
